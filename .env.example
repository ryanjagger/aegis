AIS_DATABASE_URL=sqlite:///./ais.db
AIS_DEFAULT_MODEL=mock-ais
AIS_ALLOW_PROVIDER_STORE=false

# CIFT activation-probe lab (only used when the `cift` dependency group is installed)
AIS_CIFT_MODEL=Qwen/Qwen2.5-1.5B-Instruct
AIS_CIFT_DEVICE=auto
AIS_CIFT_RIDGE=0.01
AIS_CIFT_SEED=0
AIS_CIFT_GATE=false
